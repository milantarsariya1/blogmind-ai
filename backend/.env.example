# PostgreSQL database connection URL (e.g. Neon, local, etc.)
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# Port to run the Express backend on
PORT=5000

# Secret key for signing JSON Web Tokens (JWT)
JWT_SECRET="your_jwt_secret_key_here"

# Groq API Key for AI Summarization and Grammar Correction (backend only)
GROQ_API_KEY="gsk_..."
